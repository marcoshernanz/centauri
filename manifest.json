{
  "manifest_version": 3,
  "name": "Natural Web Agent",
  "description": "Control the web through natural language.",
  "version": "0.1.0",
  "permissions": ["activeTab", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "css": ["content/ui/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-command-bar": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Toggle the natural language command bar"
    }
  }
}
